# Lerian Hub — auth environment variables
#
# These are read ONLY by lib/auth/config.ts (the single source of truth for
# auth config). Copy this file to `.env.local` and adjust as needed. With NO
# vars set, the Hub runs in zero-config "mock" mode (the prototype default).

# Auth backend: "mock" (default) | "google".
#   mock   — fixed dev identity, no real OAuth; runs with zero setup.
#   google — Google Workspace SSO; requires HUB_JWT_SECRET + GOOGLE_* below.
AUTH_MODE=mock

# JWT signing secret for the httpOnly session cookie (HS256 via jose).
#   mock mode   — optional; falls back to a fixed dev secret if unset.
#   google mode — REQUIRED, must be at least 32 characters (fail-closed:
#                 startup throws otherwise). Generate one with:
#                 openssl rand -base64 48
# HUB_JWT_SECRET=

# Cookie Domain attribute for the session cookie.
#   Leave UNSET for localhost so the cookie scopes to the current host.
#   In production set to the shared parent domain so SSO spans subdomains, e.g.
# HUB_COOKIE_DOMAIN=.lerian.studio

# Session lifetime in minutes. Default 60; values < 1 are clamped to 1.
# HUB_SESSION_TTL_MIN=60

# --- Google OAuth (only used when AUTH_MODE=google) ----------------------------
# Validated in Phase 2; present here so the contract is documented up front.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://hub.lerian.studio/api/auth/callback
